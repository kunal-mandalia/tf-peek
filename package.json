{
  "name": "tf-peek",
  "version": "0.9.2",
  "description": "Inspect TensorFlow.js model architecture and weights from the CLI or programmatically",
  "keywords": ["tensorflow", "tfjs", "model", "inspect", "weights", "debug", "cli"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kunal-mandalia/tf-peek"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "tf-peek": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0"
  }
}
